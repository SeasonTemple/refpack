{
  "name": "refpack",
  "version": "0.1.0",
  "description": "Team-first agent skill manager for packaging, distributing, installing, and maintaining reusable skills.",
  "type": "module",
  "bin": {
    "refpack": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "skillhub": "node dist/skillhub/server/entry.js",
    "test": "npm run build && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "figlet": "^1.8.0",
    "fs-extra": "^11.2.0",
    "giget": "^2.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
